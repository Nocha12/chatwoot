<script setup>
import { onMounted, ref, computed, reactive, watch } from 'vue';
import { useRoute, useRouter } from 'vue-router';
import { useI18n } from 'vue-i18n';
import { useStore, useMapGetter } from 'dashboard/composables/store';
import { debounce } from '@chatwoot/utils';
import { useUISettings } from 'dashboard/composables/useUISettings';
import * as XLSX from 'xlsx';

import ContactsListLayout from 'dashboard/components-next/Contacts/ContactsListLayout.vue';
import InvoicesList from 'dashboard/components-next/Invoices/Pages/InvoicesList.vue';
import Spinner from 'dashboard/components-next/spinner/Spinner.vue';
import Button from 'dashboard/components-next/button/Button.vue';

const DEFAULT_SORT_FIELD = 'created_at';
const DEBOUNCE_DELAY = 300;

const store = useStore();
const route = useRoute();
const router = useRouter();
const { t } = useI18n();

const { updateUISettings, uiSettings } = useUISettings();

const invoices = useMapGetter('invoices/getInvoicesList');
const uiFlags = useMapGetter('invoices/getUIFlags');
const meta = useMapGetter('invoices/getMeta');

const searchQuery = computed(() => route.query?.search);
const searchValue = ref(searchQuery.value || '');
const pageNumber = computed(() => Number(route.query?.page) || 1);

const parseSortSettings = (sortString = '') => {
  const hasDescending = sortString.startsWith('-');
  const sortField = hasDescending ? sortString.slice(1) : sortString;
  return {
    sort: sortField || DEFAULT_SORT_FIELD,
    order: hasDescending ? '-' : '',
  };
};

const { invoices_sort_by: invoicesSortBy = '' } = uiSettings.value ?? {};
const { sort: initialSort, order: initialOrder } =
  parseSortSettings(invoicesSortBy);

const sortState = reactive({
  activeSort: initialSort,
  activeOrdering: initialOrder,
});

const isFetchingList = computed(() => uiFlags.value.isFetching);
const currentPage = computed(() => Number(meta.value?.currentPage));
const totalItems = computed(() => meta.value?.count);
const hasInvoices = computed(() => invoices.value.length > 0);

// Excel 업로드 관련 상태
const fileInputRef = ref(null);
const uploadedInvoices = ref([]);
const showUploadedInvoices = ref(false);
const isProcessingFile = ref(false);

const headerTitle = computed(() =>
  searchQuery.value
    ? t('INVOICES_LAYOUT.HEADER.SEARCH_TITLE')
    : t('INVOICES_LAYOUT.HEADER.TITLE')
);

const updatePageParam = (page, search = '') => {
  const query = {
    ...route.query,
    page: page.toString(),
    ...(search ? { search } : {}),
  };

  if (!search) {
    delete query.search;
  }

  router.replace({ query });
};

const buildSortAttr = () =>
  `${sortState.activeOrdering}${sortState.activeSort}`;

const fetchInvoices = async (page = 1) => {
  await store.dispatch('invoices/get', { page, sortAttr: buildSortAttr() });
  updatePageParam(page);
};

const searchInvoices = debounce(async (value, page = 1) => {
  searchValue.value = value;

  if (!value) {
    updatePageParam(page);
    await fetchInvoices(page);
    return;
  }

  updatePageParam(page, value);
  await store.dispatch('invoices/search', {
    page,
    sortAttr: buildSortAttr(),
    search: encodeURIComponent(value),
  });
}, DEBOUNCE_DELAY);

const handleSort = async ({ sort, order }) => {
  Object.assign(sortState, { activeSort: sort, activeOrdering: order });

  await updateUISettings({ invoices_sort_by: buildSortAttr() });

  if (searchQuery.value) {
    await searchInvoices(searchValue.value);
    return;
  }

  await fetchInvoices();
};

// Excel 파일 업로드 및 처리 함수들
const handleFileUpload = () => {
  fileInputRef.value?.click();
};

const processExcelFile = file => {
  isProcessingFile.value = true;

  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = new Uint8Array(e.target.result);
      const workbook = XLSX.read(data, { type: 'array' });

      // 첫 번째 시트 가져오기
      const firstSheetName = workbook.SheetNames[0];
      const worksheet = workbook.Sheets[firstSheetName];

      // JSON으로 변환
      const jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1 });

      if (jsonData.length < 2) {
        alert('Excel 파일에 데이터가 없습니다.');
        isProcessingFile.value = false;
        return;
      }

      // 첫 번째 행은 헤더로 가정하고, 두 번째 행부터 데이터로 처리
      const headers = jsonData[0];
      const rows = jsonData.slice(1);

      const processedInvoices = rows.map((row, index) => {
        // 각 행의 데이터를 InvoiceCard props에 맞게 매핑
        // 컬럼 순서: invoiceNumber, total, status (사용자가 Excel 파일을 이 순서로 작성한다고 가정)
        return {
          id: Date.now() + index, // 임시 ID
          invoiceNumber: row[0] || `Invoice-${index + 1}`,
          total: row[1] || '',
          status: row[2] || 'pending',
          // 추가 데이터들을 details로 저장
          details: headers.reduce((acc, header, idx) => {
            if (idx > 2) {
              // 처음 3개 컬럼 이후의 데이터들
              acc[header] = row[idx] || '';
            }
            return acc;
          }, {}),
        };
      });

      uploadedInvoices.value = processedInvoices;
      showUploadedInvoices.value = true;
    } catch (error) {
      console.error('Excel 파일 처리 중 오류:', error);
      alert('Excel 파일 처리 중 오류가 발생했습니다.');
    } finally {
      isProcessingFile.value = false;
      // 파일 입력 초기화
      if (fileInputRef.value) {
        fileInputRef.value.value = '';
      }
    }
  };

  reader.readAsArrayBuffer(file);
};

const handleFileChange = event => {
  const file = event.target.files?.[0];
  if (!file) return;

  if (!file.name.match(/\.(xlsx|xls)$/)) {
    alert('Excel 파일(.xlsx, .xls)만 업로드 가능합니다.');
    return;
  }

  processExcelFile(file);
};

const clearUploadedInvoices = () => {
  uploadedInvoices.value = [];
  showUploadedInvoices.value = false;
};

const displayedInvoices = computed(() => {
  return showUploadedInvoices.value ? uploadedInvoices.value : invoices.value;
});

const hasDisplayedInvoices = computed(() => displayedInvoices.value.length > 0);

watch(searchQuery, value => {
  if (isFetchingList.value) return;
  searchValue.value = value || '';
  if (value === undefined) {
    fetchInvoices();
  }
});

onMounted(async () => {
  if (searchQuery.value) {
    await searchInvoices(searchQuery.value, pageNumber.value);
    return;
  }
  await fetchInvoices(pageNumber.value);
});
</script>

<template>
  <div
    class="flex flex-col justify-between flex-1 h-full m-0 overflow-auto bg-n-background"
  >
    <ContactsListLayout
      :search-value="searchValue"
      :header-title="headerTitle"
      :current-page="currentPage"
      :total-items="totalItems"
      :show-pagination-footer="
        !isFetchingList && hasDisplayedInvoices && !showUploadedInvoices
      "
      :active-sort="sortState.activeSort"
      :active-ordering="sortState.activeOrdering"
      :is-fetching-list="isFetchingList"
      @update:current-page="fetchInvoices"
      @search="searchInvoices"
      @update:sort="handleSort"
    >
      <!-- Excel 업로드 버튼 영역 -->
      <div class="flex justify-between items-center px-6 py-4 border-b border-n-weak">
        <h2 class="text-lg font-semibold text-n-slate-12">인보이스 관리</h2>
        <div class="flex gap-2">
          <Button
            v-if="showUploadedInvoices"
            icon="i-lucide-x"
            variant="outline"
            color="slate"
            size="sm"
            @click="clearUploadedInvoices"
          >
            업로드된 데이터 닫기
          </Button>
          <Button
            icon="i-lucide-upload"
            variant="solid"
            color="primary"
            size="sm"
            :loading="isProcessingFile"
            @click="handleFileUpload"
          >
            {{ isProcessingFile ? 'Excel 처리 중...' : 'Excel 업로드' }}
          </Button>
        </div>
      </div>

      <div
        v-if="isFetchingList"
        class="flex items-center justify-center py-10 text-n-slate-11"
      >
        <Spinner />
      </div>

      <template v-else>
        <!-- 업로드된 데이터 표시 안내 -->
        <div
          v-if="showUploadedInvoices && hasDisplayedInvoices"
          class="flex items-center justify-center py-2 mb-4 bg-blue-50 border border-blue-200 rounded-lg mx-6"
        >
          <span class="text-sm text-blue-800">
            📊 Excel 파일에서 {{ uploadedInvoices.length }}개의 인보이스를
            불러왔습니다.
          </span>
        </div>

        <div
          v-if="!hasDisplayedInvoices"
          class="flex items-center justify-center py-10"
        >
          <span class="text-base text-n-slate-11">
            {{
              showUploadedInvoices
                ? '업로드된 Excel 파일에 데이터가 없습니다.'
                : searchQuery
                  ? t('INVOICES_LAYOUT.EMPTY_STATE.SEARCH_EMPTY_STATE_TITLE')
                  : t('INVOICES_LAYOUT.EMPTY_STATE.LIST_EMPTY_STATE_TITLE')
            }}
          </span>
        </div>

        <InvoicesList v-else :invoices="displayedInvoices" />
      </template>
    </ContactsListLayout>

    <!-- 숨겨진 파일 입력 -->
    <input
      ref="fileInputRef"
      type="file"
      accept=".xlsx,.xls"
      style="display: none"
      @change="handleFileChange"
    />
  </div>
</template>
